    <edge source="R&#7888;I LO&#7840;N NH&#7882;P TH&#7844;T" target="X&#201;T NGHI&#7878;M M&#193;U">
      <data key="d8">8.0</data>
      <data key="d9">X&#233;t nghi&#7879;m m&#225;u gi&#250;p &#273;&#225;nh gi&#225; c&#225;c y&#7871;u t&#7889; c&#243; th&#7875; &#7843;nh h&#432;&#7903;ng &#273;&#7871;n nh&#7883;p tim, t&#7915; &#273;&#243; h&#7895; tr&#7907; ch&#7849;n &#273;o&#225;n r&#7889;i lo&#7841;n nh&#7883;p th&#7845;t.</data>
