    <edge source="R&#7888;I LO&#7840;N NH&#7882;P TH&#7844;T" target="&#272;I&#7878;N T&#194;M &#272;&#7890;">
      <data key="d8">9.0</data>
      <data key="d9">&#272;i&#7879;n t&#226;m &#273;&#7891; l&#224; ph&#432;&#417;ng ph&#225;p ch&#7849;n &#273;o&#225;n gi&#250;p ph&#225;t hi&#7879;n c&#225;c r&#7889;i lo&#7841;n nh&#7883;p tim, bao g&#7891;m r&#7889;i lo&#7841;n nh&#7883;p th&#7845;t.</data>
