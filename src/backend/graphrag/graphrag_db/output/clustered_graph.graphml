    <edge source="R&#7888;I LO&#7840;N NH&#7882;P TH&#7844;T" target="B&#7878;NH VAN TIM">
      <data key="d8">8.0</data>
      <data key="d9">B&#7879;nh van tim c&#243; th&#7875; l&#224;m thay &#273;&#7893;i t&#237;nh ch&#7845;t &#273;i&#7879;n h&#7885;c c&#7911;a tim, t&#7841;o &#273;i&#7873;u ki&#7879;n cho r&#7889;i lo&#7841;n nh&#7883;p th&#7845;t.</data>
      <data key="d10">8450452994017d98ea3f4f54219b67d8</data>
