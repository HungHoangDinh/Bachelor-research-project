    <edge source="R&#7888;I LO&#7840;N NH&#7882;P TH&#7844;T" target="THU&#7888;C CH&#7888;NG LO&#7840;N NH&#7882;P">
      <data key="d8">9.0</data>
      <data key="d9">Thu&#7889;c ch&#7889;ng lo&#7841;n nh&#7883;p &#273;&#432;&#7907;c s&#7917; d&#7909;ng &#273;&#7875; &#273;i&#7873;u tr&#7883; v&#224; ki&#7875;m so&#225;t c&#225;c c&#417;n r&#7889;i lo&#7841;n nh&#7883;p th&#7845;t, gi&#250;p &#7893;n &#273;&#7883;nh nh&#7883;p tim.</data>
      <data key="d10">e8614181c1c96a52140d67b12b26678f</data>
      <data key="d11">93c4d33976c8437e9ad30233a59737a9</data>
      <data key="d12">15</data>
