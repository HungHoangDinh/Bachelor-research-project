    <edge source="R&#7888;I LO&#7840;N NH&#7882;P TH&#7844;T" target="C&#193;C C&#193;CH GI&#7842;M NGUY C&#416;">
      <data key="d8">7.0</data>
      <data key="d9">C&#225;c c&#225;ch gi&#7843;m nguy c&#417; c&#243; th&#7875; gi&#250;p ng&#432;&#7901;i b&#7879;nh ki&#7875;m so&#225;t t&#236;nh tr&#7841;ng r&#7889;i lo&#7841;n nh&#7883;p th&#7845;t v&#224; c&#7843;i thi&#7879;n s&#7913;c kh&#7887;e tim m&#7841;ch.</data>
      <data key="d10">29761ccf674424887a8b37873b591d4e</data>
