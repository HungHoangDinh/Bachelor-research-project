    <node id="THI&#7870;U OXY">
      <data key="d0">TERM</data>
      <data key="d1">Thi&#7871;u oxy l&#224; t&#236;nh tr&#7841;ng m&#224; c&#417; tim kh&#244;ng nh&#7853;n &#273;&#7911; oxy, c&#243; th&#7875; d&#7851;n &#273;&#7871;n r&#7889;i lo&#7841;n nh&#7883;p th&#7845;t do &#7843;nh h&#432;&#7903;ng &#273;&#7871;n ho&#7841;t &#273;&#7897;ng &#273;i&#7879;n h&#7885;c c&#7911;a tim.</data>
