    <edge source="R&#7888;I LO&#7840;N NH&#7882;P TH&#7844;T" target="B&#7878;NH VI&#7878;N &#272;A KHOA T&#194;M ANH">
      <data key="d8">9.0</data>
      <data key="d9">B&#7879;nh vi&#7879;n &#272;a khoa T&#226;m Anh c&#243; chuy&#234;n khoa tim m&#7841;ch, n&#417;i ng&#432;&#7901;i b&#7879;nh c&#243; th&#7875; &#273;&#432;&#7907;c th&#259;m kh&#225;m v&#224; &#273;i&#7873;u tr&#7883; r&#7889;i lo&#7841;n nh&#7883;p th&#7845;t.</data>
      <data key="d10">29761ccf674424887a8b37873b591d4e</data>
      <data key="d11">2b162e1f80554871be2dece37b2e9081</data>
      <data key="d12">29</data>
