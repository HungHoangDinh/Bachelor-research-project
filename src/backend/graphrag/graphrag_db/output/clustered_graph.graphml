    <edge source="R&#7888;I LO&#7840;N NH&#7882;P TH&#7844;T" target="M&#193;Y KH&#7916; RUNG TIM NGO&#192;I T&#7920; &#272;&#7896;NG">
      <data key="d8">9.0</data>
      <data key="d9">M&#225;y kh&#7917; rung tim ngo&#224;i t&#7921; &#273;&#7897;ng &#273;&#432;&#7907;c s&#7917; d&#7909;ng &#273;&#7875; &#273;i&#7873;u tr&#7883; r&#7889;i lo&#7841;n nh&#7883;p th&#7845;t b&#7857;ng c&#225;ch ph&#225;t ra xung &#273;i&#7879;n nh&#7857;m &#273;&#432;a tim v&#7873; nh&#7883;p b&#236;nh th&#432;&#7901;ng.</data>
      <data key="d10">e8614181c1c96a52140d67b12b26678f</data>
      <data key="d11">1e41fb985e864ac4a5a0ed61cc0fa749</data>
      <data key="d12">18</data>
