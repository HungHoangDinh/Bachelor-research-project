    <edge source="R&#7888;I LO&#7840;N NH&#7882;P TH&#7844;T" target="H&#7890;I S&#7912;C TIM PH&#7892;I">
      <data key="d8">9.0</data>
      <data key="d9">H&#7891;i s&#7913;c tim ph&#7893;i l&#224; bi&#7879;n ph&#225;p c&#7845;p c&#7913;u c&#7847;n thi&#7871;t khi b&#7879;nh nh&#226;n b&#7883; ng&#7915;ng tim do r&#7889;i lo&#7841;n nh&#7883;p th&#7845;t.</data>
      <data key="d10">e8614181c1c96a52140d67b12b26678f</data>
      <data key="d11">6302f294f574480fbb935d290bec85cf</data>
      <data key="d12">19</data>
