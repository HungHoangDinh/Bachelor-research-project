      <data key="d0">TERM</data>
      <data key="d1">T&#225;c d&#7909;ng ph&#7909; c&#7911;a thu&#7889;c l&#224; nh&#7919;ng &#7843;nh h&#432;&#7903;ng kh&#244;ng mong mu&#7889;n t&#7915; vi&#7879;c s&#7917; d&#7909;ng thu&#7889;c, c&#243; th&#7875; g&#226;y r&#7889;i lo&#7841;n nh&#7883;p th&#7845;t &#7903; b&#7879;nh nh&#226;n c&#243; y&#7871;u t&#7889; nguy c&#417;.</data>
