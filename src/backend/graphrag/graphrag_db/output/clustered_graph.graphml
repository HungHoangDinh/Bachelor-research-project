      <data key="d9">B&#7879;nh tim b&#7849;m sinh c&#243; th&#7875; g&#226;y ra b&#7845;t th&#432;&#7901;ng trong h&#7879; th&#7889;ng d&#7851;n truy&#7873;n &#273;i&#7879;n h&#7885;c c&#7911;a tim, d&#7851;n &#273;&#7871;n r&#7889;i lo&#7841;n nh&#7883;p th&#7845;t.</data>
      <data key="d10">8450452994017d98ea3f4f54219b67d8</data>
      <data key="d11">4d35abe822d64ec0ba167fb49bc26592</data>
      <data key="d12">10</data>
