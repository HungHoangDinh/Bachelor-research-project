    <edge source="NH&#7882;P NHANH TH&#7844;T" target="RUNG TH&#7844;T">
      <data key="d8">9.0</data>
      <data key="d9">Nh&#7883;p nhanh th&#7845;t n&#7871;u kh&#244;ng &#273;&#432;&#7907;c &#273;i&#7873;u tr&#7883; c&#243; th&#7875; d&#7851;n &#273;&#7871;n rung th&#7845;t, g&#226;y nguy hi&#7875;m cho t&#237;nh m&#7841;ng.</data>
      <data key="d10">8450452994017d98ea3f4f54219b67d8</data>
