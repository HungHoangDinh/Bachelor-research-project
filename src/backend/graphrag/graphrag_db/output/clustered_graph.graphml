    <edge source="R&#7888;I LO&#7840;N NH&#7882;P TH&#7844;T" target="&#272;I&#7872;U TR&#7882; V&#192; KI&#7874;M SO&#193;T LO&#7840;N NH&#7882;P">
      <data key="d8">1.0</data>
      <data key="d9">&#272;i&#7873;u tr&#7883; v&#224; ki&#7875;m so&#225;t lo&#7841;n nh&#7883;p l&#224; m&#7909;c ti&#234;u ch&#237;nh trong vi&#7879;c qu&#7843;n l&#253; r&#7889;i lo&#7841;n nh&#7883;p th&#7845;t &#273;&#7875; n&#226;ng cao ch&#7845;t l&#432;&#7907;ng s&#7889;ng cho ng&#432;&#7901;i b&#7879;nh.</data>
      <data key="d10">29761ccf674424887a8b37873b591d4e</data>
      <data key="d11">eab2bccd70c247fca36e9a03bf72422b</data>
