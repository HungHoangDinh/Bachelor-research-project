    <edge source="R&#7888;I LO&#7840;N NH&#7882;P TH&#7844;T" target="Y&#7870;U T&#7888; NGUY C&#416;">
      <data key="d8">8.0</data>
      <data key="d9">Y&#7871;u t&#7889; nguy c&#417; c&#243; th&#7875; l&#224;m t&#259;ng kh&#7843; n&#259;ng x&#7843;y ra r&#7889;i lo&#7841;n nh&#7883;p th&#7845;t &#7903; b&#7879;nh nh&#226;n, d&#7851;n &#273;&#7871;n c&#225;c bi&#7871;n ch&#7913;ng nghi&#234;m tr&#7885;ng.</data>
      <data key="d10">e8614181c1c96a52140d67b12b26678f</data>
