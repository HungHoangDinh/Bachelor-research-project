    <node id="R&#7888;I LO&#7840;N NH&#7882;P TH&#7844;T">
      <data key="d0">TERM</data>
      <data key="d1">R&#7889;i lo&#7841;n nh&#7883;p th&#7845;t l&#224; t&#236;nh tr&#7841;ng b&#7845;t th&#432;&#7901;ng c&#7911;a nh&#7883;p tim, x&#7843;y ra khi &#7893; ph&#225;t nh&#7883;p ngo&#7841;i lai kh&#7903;i ph&#225;t t&#7915; t&#226;m th&#7845;t, d&#7851;n &#273;&#7871;n s&#7921; co b&#243;p kh&#244;ng &#273;&#7891;ng b&#7897; c&#7911;a t&#226;m th&#7845;t. T&#236;nh tr&#7841;ng n&#224;y &#7843;nh h&#432;&#7903;ng nghi&#234;m tr&#7885;ng &#273;&#7871;n hi&#7879;u qu&#7843; b&#417;m m&#225;u c&#7911;a tim v&#224; c&#243; th&#7875; g&#226;y ra c&#225;c bi&#7871;n ch&#7913;ng nguy hi&#7875;m nh&#432; suy tim v&#224; &#273;&#7897;t t&#7917; do tim n&#7871;u kh&#244;ng &#273;&#432;&#7907;c ch&#7849;n &#273;o&#225;n v&#224; &#273;i&#7873;u tr&#7883; k&#7883;p th&#7901;i. Ng&#432;&#7901;i b&#7879;nh c&#243; th&#7875; tr&#7843;i qua c&#225;c tri&#7879;u ch&#7913;ng nghi&#234;m tr&#7885;ng, &#7843;nh h&#432;&#7903;ng &#273;&#7871;n s&#7913;c kh&#7887;e t&#7893;ng th&#7875; c&#7911;a h&#7885;.</data>
      <data key="d2">29761ccf674424887a8b37873b591d4e,8450452994017d98ea3f4f54219b67d8,e8614181c1c96a52140d67b12b26678f</data>
      <data key="d3">0</data>
      <data key="d4">0</data>
      <data key="d5">35</data>
      <data key="d6">0</data>
      <data key="d7">059c5704d98e479088789b9a49053d89</data>
    </node>
    <node id="NGUY&#202;N NH&#194;N G&#194;Y R&#7888;I LO&#7840;N NH&#7882;P TH&#7844;T">
      <data key="d0">TERM</data>
      <data key="d1">Nguy&#234;n nh&#226;n g&#226;y r&#7889;i lo&#7841;n nh&#7883;p th&#7845;t bao g&#7891;m t&#7893;n th&#432;&#417;ng c&#417; tim, suy tim, vi&#234;m tim, m&#7845;t c&#226;n b&#7857;ng &#273;i&#7879;n gi&#7843;i, b&#7879;nh c&#417; tim, b&#7879;nh tim b&#7849;m sinh, b&#7879;nh van tim, thi&#7871;u oxy, t&#225;c d&#7909;ng ph&#7909; c&#7911;a thu&#7889;c v&#224; t&#236;nh tr&#7841;ng sau ph&#7851;u thu&#7853;t tim.</data>
      <data key="d2">8450452994017d98ea3f4f54219b67d8</data>
      <data key="d3">0</data>
      <data key="d4">0</data>
      <data key="d5">1</data>
      <data key="d6">1</data>
      <data key="d7">07f858eedb6d4841a75509d61edd904e</data>
    </node>
    <node id="NGO&#7840;I T&#194;M THU TH&#7844;T">
      <data key="d0">TERM</data>
      <data key="d1">Ngo&#7841;i t&#226;m thu th&#7845;t l&#224; m&#7897;t nh&#7883;p ngo&#7841;i lai kh&#7903;i ph&#225;t t&#7915; t&#226;m th&#7845;t, c&#243; th&#7875; g&#7863;p &#7903; ng&#432;&#7901;i b&#236;nh th&#432;&#7901;ng ho&#7863;c ng&#432;&#7901;i c&#243; b&#7879;nh tim c&#7845;u tr&#250;c tr&#432;&#7899;c &#273;&#243;.</data>
      <data key="d2">8450452994017d98ea3f4f54219b67d8</data>
