    <edge source="R&#7888;I LO&#7840;N NH&#7882;P TH&#7844;T" target="PH&#7850;U THU&#7852;T TIM">
      <data key="d8">1.0</data>
      <data key="d9">Ph&#7851;u thu&#7853;t tim c&#243; th&#7875; &#273;&#7875; l&#7841;i v&#7871;t s&#7865;o v&#224; g&#226;y ra r&#7889;i lo&#7841;n nh&#7883;p th&#7845;t sau ph&#7851;u thu&#7853;t.</data>
      <data key="d10">8450452994017d98ea3f4f54219b67d8</data>
      <data key="d11">d9c703da7e8241e4a53a2bec038a9a29</data>
