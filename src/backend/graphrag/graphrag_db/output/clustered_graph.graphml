    <edge source="R&#7888;I LO&#7840;N NH&#7882;P TH&#7844;T" target="C&#193;C TRI&#7878;U CH&#7912;NG NGHI&#202;M TR&#7884;NG">
      <data key="d8">8.0</data>
      <data key="d9">C&#225;c tri&#7879;u ch&#7913;ng nghi&#234;m tr&#7885;ng l&#224; d&#7845;u hi&#7879;u cho th&#7845;y ng&#432;&#7901;i b&#7879;nh c&#243; th&#7875; &#273;ang g&#7863;p ph&#7843;i r&#7889;i lo&#7841;n nh&#7883;p th&#7845;t v&#224; c&#7847;n &#273;&#432;&#7907;c h&#7895; tr&#7907; y t&#7871;.</data>
      <data key="d10">29761ccf674424887a8b37873b591d4e</data>
      <data key="d11">11d2c86942b2494898a8f158d96d9098</data>
      <data key="d12">30</data>
