    <node id="VI&#202;M TIM">
      <data key="d0">TERM</data>
      <data key="d1">Vi&#234;m tim l&#224; t&#236;nh tr&#7841;ng vi&#234;m nhi&#7877;m trong c&#417; tim, c&#243; th&#7875; g&#226;y ra c&#225;c v&#249;ng ph&#249; n&#7873; v&#224; ho&#7841;i t&#7917;, d&#7851;n &#273;&#7871;n r&#7889;i lo&#7841;n nh&#7883;p th&#7845;t.</data>
