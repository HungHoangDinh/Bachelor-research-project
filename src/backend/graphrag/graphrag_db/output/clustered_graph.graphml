      <data key="d0">TERM</data>
      <data key="d1">Tri&#7879;u ch&#7913;ng r&#7889;i lo&#7841;n nh&#7883;p th&#7845;t l&#224; c&#225;c bi&#7875;u hi&#7879;n l&#226;m s&#224;ng m&#224; b&#7879;nh nh&#226;n c&#243; th&#7875; g&#7863;p ph&#7843;i, bao g&#7891;m nh&#7883;p nhanh th&#7845;t ho&#7863;c rung th&#7845;t, c&#243; th&#7875; xu&#7845;t hi&#7879;n &#273;&#7897;t ng&#7897;t v&#224; n&#7863;ng h&#417;n nhanh ch&#243;ng.</data>
