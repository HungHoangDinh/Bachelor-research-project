      <data key="d0">TERM</data>
      <data key="d1">M&#7845;t c&#226;n b&#7857;ng &#273;i&#7879;n gi&#7843;i l&#224; t&#236;nh tr&#7841;ng r&#7889;i lo&#7841;n c&#225;c ch&#7845;t &#273;i&#7879;n gi&#7843;i trong m&#225;u, &#7843;nh h&#432;&#7903;ng &#273;&#7871;n ho&#7841;t &#273;&#7897;ng &#273;i&#7879;n h&#7885;c c&#7911;a t&#7871; b&#224;o c&#417; tim, c&#243; th&#7875; g&#226;y r&#7889;i lo&#7841;n nh&#7883;p th&#7845;t.</data>
