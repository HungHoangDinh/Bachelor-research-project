    <edge source="R&#7888;I LO&#7840;N NH&#7882;P TH&#7844;T" target="C&#193;C PH&#431;&#416;NG PH&#193;P C&#7852;N L&#194;M S&#192;NG">
      <data key="d8">1.0</data>
      <data key="d9">C&#225;c ph&#432;&#417;ng ph&#225;p c&#7853;n l&#226;m s&#224;ng &#273;&#432;&#7907;c s&#7917; d&#7909;ng &#273;&#7875; h&#7895; tr&#7907; ch&#7849;n &#273;o&#225;n v&#224; t&#236;m nguy&#234;n nh&#226;n c&#7911;a r&#7889;i lo&#7841;n nh&#7883;p th&#7845;t.</data>
      <data key="d10">e8614181c1c96a52140d67b12b26678f</data>
      <data key="d11">d88facf2c06045468f021f3a06802a74</data>
