    <edge source="R&#7888;I LO&#7840;N NH&#7882;P TH&#7844;T" target="B&#7878;NH NH&#194;N SAU PH&#7850;U THU&#7852;T TIM">
      <data key="d8">8.0</data>
      <data key="d9">B&#7879;nh nh&#226;n sau ph&#7851;u thu&#7853;t tim c&#243; nguy c&#417; cao b&#7883; r&#7889;i lo&#7841;n nh&#7883;p th&#7845;t do v&#7871;t s&#7865;o v&#224; t&#236;nh tr&#7841;ng vi&#234;m trong c&#417; tim.</data>
      <data key="d10">e8614181c1c96a52140d67b12b26678f</data>
      <data key="d11">b85fb2110da44ea0960df9e334674460</data>
