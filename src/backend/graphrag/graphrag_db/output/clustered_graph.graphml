    <edge source="R&#7888;I LO&#7840;N NH&#7882;P TH&#7844;T" target="NGUY&#202;N NH&#194;N G&#194;Y B&#7878;NH">
      <data key="d8">8.0</data>
      <data key="d9">Nguy&#234;n nh&#226;n g&#226;y b&#7879;nh c&#243; th&#7875; l&#224; y&#7871;u t&#7889; di truy&#7873;n ho&#7863;c t&#236;nh tr&#7841;ng m&#227;n t&#237;nh, &#7843;nh h&#432;&#7903;ng &#273;&#7871;n s&#7921; ph&#225;t tri&#7875;n c&#7911;a r&#7889;i lo&#7841;n nh&#7883;p th&#7845;t.</data>
